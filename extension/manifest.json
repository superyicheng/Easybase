{
  "manifest_version": 3,
  "name": "Easybase",
  "version": "1.0.0",
  "description": "Inject knowledge base context into AI chats (ChatGPT, Claude.ai, Gemini)",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:8372/*",
    "http://localhost:8372/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
